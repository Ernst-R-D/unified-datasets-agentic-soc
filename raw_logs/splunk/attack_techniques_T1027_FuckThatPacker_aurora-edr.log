{"preview":false,"result":{"_raw":"{\"Computer\":\"win-dc-jhernandez-17500-200\",\"Correlation_ActivityID\":\"{BF6FE7CE-3AE2-0007-64EE-6FBFE23AD801}\",\"EventID\":\"4104\",\"Execution_ProcessID\":\"6772\",\"Execution_ThreadID\":\"6884\",\"Keywords\":\"0x0\",\"Level\":\"3\",\"Match_Strings\":\"Start-Process in ScriptBlockText, '-FilePath ' in ScriptBlockText, '-PassThru ' in ScriptBlockText\",\"MessageNumber\":\"1\",\"MessageTotal\":\"2\",\"Module\":\"Sigma\",\"Opcode\":\"15\",\"Path\":\"C:\\\\ProgramData\\\\Amazon\\\\EC2-Windows\\\\Launch\\\\Module\\\\Scripts\\\\Install-EgpuManager.ps1\",\"Provider_Guid\":\"{A0C1853B-5C40-4B15-8766-3CF1C58F985A}\",\"Provider_Name\":\"Microsoft-Windows-PowerShell\",\"Rule_Author\":\"frack113\",\"Rule_Description\":\"Powershell use PassThru option to start in background\",\"Rule_FalsePositives\":\"Legitimate PowerShell scripts\",\"Rule_Id\":\"0718cd72-f316-4aa2-988f-838ea8533277\",\"Rule_Level\":\"medium\",\"Rule_Link\":\"https://github.com/SigmaHQ/sigma/blob/0.20-3312-gfbf1b845/rules/windows/powershell/powershell_script/posh_ps_suspicious_start_process.yml\",\"Rule_Modified\":\"2022/01/15\",\"Rule_Path\":\"public\\\\windows\\\\powershell\\\\powershell_script\\\\posh_ps_suspicious_start_process.yml\",\"Rule_References\":\"https://github.com/redcanaryco/atomic-red-team/blob/master/atomics/T1036.003/T1036.003.md, https://docs.microsoft.com/en-us/powershell/module/microsoft.powershell.management/Start-Process?view=powershell-5.1\\u0026viewFallbackFrom=powershell-7\",\"Rule_Sigtype\":\"public\",\"Rule_Title\":\"Suspicious Start-Process PassThru\",\"ScriptBlockId\":\"4156a7f7-4c0b-4f25-afea-3ba0426b5676\",\"ScriptBlockText\":\"#----------------------------------------------------------------------------------------------------\\r\\n#\\r\\n#    Copyright 2017 Amazon.com, Inc. or its affiliates. All Rights Reserved.\\r\\n#\\r\\n#    Licensed under the Customer Agreement (the \\\"License\\\").\\r\\n#\\r\\n#    You may not use this file except