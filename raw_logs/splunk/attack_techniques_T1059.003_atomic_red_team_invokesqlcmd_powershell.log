            $TableHTMLText += "&lt;th&gt;" + $ColumnName.toString() + "&lt;/th&gt;"
        }
        $TableHTMLText += "&lt;/tr&gt;"
        $TableSchema = @{ }
        $TableSchema["fields"] = $TableSchemaFeilds

