            $CellExecutionCount
        )
        $TableHTMLText = "&lt;table&gt;"
        $TableSchemaFeilds = @()
        $TableHTMLText += "&lt;tr&gt;"
        foreach ($ColumnName in $DataTable.Columns) {
            $TableSchemaFeilds += @(@{name = $ColumnName.toString() })
            $TableHTMLText += "&lt;th&gt;" + $ColumnName.toString() + "&lt;/th&gt;"
