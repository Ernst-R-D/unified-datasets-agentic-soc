            $TableDataRow = [ordered]@{ }
            $TableHTMLText += "&lt;tr&gt;"
            $i = 0
            foreach ($Cell in $Row.ItemArray) {
                $TableDataRow[$i.ToString()] = $Cell.toString()
                $TableHTMLText += "&lt;td&gt;" + $Cell.toString() + "&lt;/td&gt;"
                $i++
            }
